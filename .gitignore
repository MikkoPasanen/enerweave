*.h2.db
*.mv.db

# Maven and Gradle dependencies
.mvn/
!.mvn/wrapper/maven-wrapper.jar
**/mvnw
**/mvnw.cmd
**/.mvn/wrapper
.gradle/
build/

# IntelliJ
.idea/
*.iml

# Eclipse
.project
.classpath
.settings/
